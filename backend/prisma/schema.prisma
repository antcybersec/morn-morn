generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  tasks Task[]
}

model Task {
  id                String   @id @default(uuid())
  title             String
  description       String
  completeInHours   Int
  aiSuggestion      String?
  dateCreated       DateTime @default(now())
  deadlineTimestamp DateTime
  challengeStop     Boolean  @default(false)
  completed         Boolean  @default(false)
  proofImageUrl     String?
  proofExplanation  String?
  aiVerdict         Boolean?

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
